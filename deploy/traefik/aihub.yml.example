# Plantilla de configuración dinámica de Traefik (file provider) para el servidor
# CodeHive. Copiar al directorio dinámico de Traefik ajustando dominios y la red.
# Los contenedores aihub-gateway y aihub-panel deben estar unidos a la red que usa
# Traefik (añadirla como red externa en un override de compose del servidor).
http:
  routers:
    aihub-api:
      rule: Host(`api.aihub.EXAMPLE.COM`)
      entryPoints: [websecure]
      tls: { certResolver: letsencrypt }
      service: aihub-gateway
      middlewares: [aihub-upload-limit]
    aihub-panel:
      rule: Host(`aihub.EXAMPLE.COM`)
      entryPoints: [websecure]
      tls: { certResolver: letsencrypt }
      service: aihub-panel

  middlewares:
    aihub-upload-limit:
      buffering:
        maxRequestBodyBytes: 209715200   # 200 MB (audio largo)

  services:
    aihub-gateway:
      loadBalancer:
        servers: [{ url: "http://aihub-gateway:8000" }]
    aihub-panel:
      loadBalancer:
        servers: [{ url: "http://aihub-panel:80" }]
