# Plantilla de configuración dinámica de Traefik (file provider).
# En el servidor CodeHive el fichero real es
# infrastructure/traefik/dynamic/deployment-aihub.yml y apunta al host_port
# del panel (único servicio público del stack: sirve SPA + /api + /v1).
http:
  routers:
    deploy-aihub:
      rule: Host(`aihub.code-hive.space`)
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt
      service: deploy-aihub

  services:
    deploy-aihub:
      loadBalancer:
        servers:
          - url: http://127.0.0.1:HOST_PORT
